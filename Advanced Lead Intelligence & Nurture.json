        "jsCode": "const rawText = $json.content[0].text;\n\n// This regex removes the ```json and ``` marks if the AI included them\nconst cleanJson = rawText.replace(/```json|```/g, \"\").trim();\n\ntry {\n  const parsedData = JSON.parse(cleanJson);\n  return [{\n    json: parsedData\n  }];\n} catch (error) {\n  // If the AI messes up the JSON, this prevents the workflow from crashing\n  return [{\n    json: {\n      error: \"Failed to parse AI response\",\n      raw: rawText\n    }\n  }];\n}"
      },
