    {
      "parameters": {
        "jsCode": "// Get data from the previous node\nconst lead = items[0].json;\nlet score = 0;\n\n// 1. Budget Logic (Max 40 points)\nif (lead.budget >= 100000) {\n  score += 40;\n} else if (lead.budget >= 50000) {\n  score += 20;\n}\n\n// 2. Timeline Logic (Max 30 points)\nif (lead.timeline === 'immediate' || lead.timeline === 'urgent') {\n  score += 30;\n} else if (lead.timeline === '1-3 months') {\n  score += 15;\n}\n\n// 3. Interest Logic (Max 30 points)\nif (lead.product_interest === 'automation' || lead.product_interest === 'ai') {\n  score += 30;\n}\n\n// Attach the final score back to the JSON object\nreturn [{\n  json: {\n    ...lead,\n    lead_score: score,\n    priority: score >= 70 ? 'HOT' : 'COLD'\n  }\n}];"
      },
