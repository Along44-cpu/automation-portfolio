      "parameters": {
        "jsCode": "return [{\n  json: {\n    name: $json.body.name ? $json.body.name.trim() : \"Unknown\",\n    email: $json.body.email ? $json.body.email.toLowerCase().trim() : \"\",\n    company: $json.body.company ? $json.body.company.trim() : \"N/A\",\n    budget: $json.body.budget ? parseFloat($json.body.budget) : 0,\n    timeline: $json.body.timeline ? $json.body.timeline.toLowerCase() : \"unknown\",\n    product_interest: $json.body.product_interest ? $json.body.product_interest.toLowerCase() : \"none\",\n    received_at: new Date().toISOString().slice(0, 19).replace('T', ' ')\n  }\n}];;"
